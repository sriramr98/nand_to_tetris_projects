// File name: projects/1/Or.hdl
/**
 * Or gate:
 * if (a or b) out = 1, else out = 0 
 */
CHIP Xor {
    IN a, b;
    OUT out;

    PARTS:
    //// Replace this comment with your code.
    Not(in=a, out=notA);
    Not(in=b, out=notB);
    
    And(a=a, b=notB, out=aAndNotB);
    And(a=b, b=notA, out=bAndNotA);

    Or(a=aAndNotB, b=bAndNotA, out=out);
}